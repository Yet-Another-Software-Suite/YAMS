{
  "permissions": {
    "allow": [
      "Bash(grep -v '\\\\.java$')",
      "Bash(codespell --version)",
      "Bash(git add README.md docs/README.md)",
      "Bash(git commit -m \"fix: grammar and spelling in Markdown documentation\")",
      "Bash(for file in \"yams/java/yams/math/LQRConfig.java\" \"yams/java/yams/motorcontrollers/SmartMotorControllerConfig.java\" \"yams/java/yams/math/ExponentialProfilePIDController.java\" \"yams/java/yams/mechanisms/config/DifferentialMechanismConfig.java\" \"yams/java/yams/mechanisms/positional/Elevator.java\" \"yams/java/yams/mechanisms/swerve/utility/SwerveInputStream.java\" \"yams/java/yams/units/EasyCRT.java\" \"yams/java/yams/motorcontrollers/local/SparkWrapper.java\")",
      "Bash(do echo \"=== $file ===\")",
      "Bash(2 git show HEAD:$file)",
      "Bash(git show HEAD~1:$file)",
      "Bash(git reset --soft HEAD~1)",
      "Bash(git add yams/java/yams/mechanisms/velocity/FlyWheel.java yams/java/yams/motorcontrollers/SmartMotorController.java)",
      "Bash(/tmp/verify_commit.sh:*)",
      "Bash(bash /tmp/verify_commit.sh)",
      "Bash(codespell --skip=\".git,build,gradle,*.jar,*.class,*.png,*.gif,vendordep/.gradle,codespell-*.txt\" .)",
      "Bash(tee codespell-clean-report.txt)",
      "Bash(xargs grep -h \"@param\")",
      "Bash(sed 's/.*@param\\\\s*\\\\w*\\\\s*//')",
      "Bash(xargs -0 grep -n '\\\\b\\\\\\([a-z_][a-z_]*\\\\\\)\\\\s\\\\+\\\\1\\\\b')",
      "Bash(xargs grep -En \"public\\\\s+\\\\w+\\\\s+get[a-z]\")",
      "Bash(find ./yams -name \"*.java\" -type f -exec grep -En '\\\\b\\(\\\\w+\\)\\\\s+\\\\1\\\\b' {} +)",
      "Bash(while read file)",
      "Bash(do grep -n \"type type\" \"$file\")",
      "Bash(echo \"File: $file\")",
      "Bash(done)",
      "Bash(find ./yams -name \"*.java\" -type f -exec grep -En '\\\\s\\(\\\\w+\\)\\\\s+\\\\1\\(\\\\s|$|\\\\.|,|;|:\\)' {} +)",
      "Bash(find ./yams -name \"*.java\" -type f -exec grep -En '\\\\*.*\\\\b\\(\\\\w+\\)\\\\s+\\\\1\\\\b|\\\\s//.*\\\\b\\(\\\\w+\\)\\\\s+\\\\1\\\\b|\\\\\"\".*\\\\b\\(\\\\w+\\)\\\\s+\\\\1\\\\b' {} +)",
      "Bash(for word in \"the\" \"is\" \"and\" \"of\" \"to\" \"in\" \"a\" \"for\" \"with\" \"be\" \"was\" \"been\" \"that\" \"this\")",
      "Bash(do echo \"=== Searching for ''$word $word'' ===\")",
      "Bash(find ./yams -name \"*.java\" -type f -exec grep -in \"$word $word\" {} +)",
      "Bash(find ./yams -name \"*.java\" -type f -exec grep -i \"will will\\\\|should should\\\\|could could\\\\|would would\\\\|might might\\\\|must must\\\\|need need\\\\|want want\\\\|have have\\\\|make make\\\\|get get\\\\|set set\\\\|use use\" {} +)",
      "Bash(codespell --skip=\".git,build,gradle,*.jar,*.class,*.png,*.gif,vendordep/.gradle,.claude\" yams examples --quiet)",
      "Bash(codespell --skip=\".git,build,gradle,*.jar,*.class,*.png,*.gif,vendordep/.gradle,.claude\" yams examples)",
      "Bash(codespell README.md docs/README.md EasyCRTConfigGuide.md)",
      "Bash(codespell vendordep/README.md vendordep/src)",
      "Bash(typos --version)",
      "Bash(typos --skip .git --skip build --skip gradle --skip vendordep/.gradle --skip .claude)",
      "Bash(typos --help)",
      "Bash(typos yams examples)"
    ]
  }
}
